<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>DEW</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  <filter>
    <filter-name>Logs</filter-name>
    <filter-class>dew.filters.LogsFilter</filter-class>
	    <init-param>
	    <param-name>logFilePath</param-name>
	    <param-value>/tmp/nol2526-access.log</param-value>
	</init-param>
	
	<init-param>
	    <param-name>active</param-name>
	    <param-value>true</param-value>
	</init-param>
  </filter>
  
  <filter-mapping>
    <filter-name>Logs</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>
	  
	  <filter>
	    <filter-name>AuthFilter</filter-name>
	    <filter-class>dew.filters.AuthFilter</filter-class>
	</filter>
	
	<filter-mapping>
	    <filter-name>AuthFilter</filter-name>
	    <url-pattern>/alumno/*</url-pattern>
	</filter-mapping>
	
	<filter-mapping>
	    <filter-name>AuthFilter</filter-name>
	    <url-pattern>/profesor/*</url-pattern>
	</filter-mapping>
	  
  <servlet>
    <servlet-name>AlumnoAsignaturasServlet</servlet-name>
    <servlet-class>dew.servlets.AlumnoAsignaturasServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AlumnoAsignaturasServlet</servlet-name>
    <url-pattern>/alumno/asignaturas</url-pattern>
  </servlet-mapping>
  

	  
	  <security-role>
	    <role-name>rolalu</role-name>
	</security-role>
	<security-role>
	    <role-name>rolpro</role-name>
	</security-role>
	
	<security-constraint>
	    <web-resource-collection>
	        <web-resource-name>Area de Profesores</web-resource-name>
	        <url-pattern>/profesor/*</url-pattern>
	    </web-resource-collection>
	    <auth-constraint>
	        <role-name>rolpro</role-name>
	    </auth-constraint>
	</security-constraint>
	
	<security-constraint>
	    <web-resource-collection>
	        <web-resource-name>Area de Alumnos</web-resource-name>
	        <url-pattern>/alumno/*</url-pattern>
	    </web-resource-collection>
	    <auth-constraint>
	        <role-name>rolalu</role-name>
	    </auth-constraint>
	</security-constraint>
	
	<login-config>
	    <auth-method>FORM</auth-method>
	    <realm-name>Notas OnLine</realm-name>
	    <form-login-config>
	    	<form-login-page>/login.html</form-login-page>
	    	<form-error-page>/login.html</form-error-page>
	    </form-login-config>
	</login-config>


  <servlet>
    <servlet-name>AsignaturasServlet</servlet-name>
    <servlet-class>dew.servlets.AsignaturasServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AsignaturasServlet</servlet-name>
    <url-pattern>/AsignaturasServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>LoginRedirectServlet</servlet-name>
    <servlet-class>dew.servlets.LoginRedirectServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginRedirectServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>AlumnoDetalleServlet</servlet-name>
    <servlet-class>dew.servlets.AlumnoDetalleServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AlumnoDetalleServlet</servlet-name>
    <url-pattern>/alumno/Detalle</url-pattern>
  </servlet-mapping>
  
  
  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>dew.servlets.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>AlumnoExpedienteServlet</servlet-name>
    <servlet-class>dew.servlets.AlumnoExpedienteServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AlumnoExpedienteServlet</servlet-name>
	<url-pattern>/alumno/Expediente</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>AsignaturaAlumnos</servlet-name>
    <servlet-class>dew.servlets.AsignaturaAlumnos</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>AsignaturaAlumnos</servlet-name>
    <url-pattern>/profesor/alumnos</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ProfesorAsignaturasServlet</servlet-name>
    <servlet-class>dew.servlets.ProfesorAsignaturasServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ProfesorAsignaturasServlet</servlet-name>
    <url-pattern>/profesor/asignaturas</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ModificarNota</servlet-name>
    <servlet-class>dew.servlets.ModificarNota</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ModificarNota</servlet-name>
    <url-pattern>/profesor/modificar-nota</url-pattern>
</servlet-mapping>

</web-app>
